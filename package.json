{
  "name": "litehub",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx --watch src/server.ts",
    "dev:bun": "bun run --watch src/server.ts",
    "start": "npx tsx src/server.ts",
    "start:bun": "bun run src/server.ts",
    "deploy:vercel": "vercel",
    "deploy:vercel:prod": "vercel --prod",
    "deploy:cf": "wrangler deploy",
    "deploy:docker": "docker build -t litehub . && docker run -d -p 3000:3000 -v litehub-data:/app/data litehub"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/hono": "^2.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/mcp-adapter": "^0.3.2",
    "hono": "^4.12.14",
    "node-fetch": "^3.3.2",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.0",
    "@types/uuid": "^9.0.0",
    "bun-types": "^1.0.0",
    "typescript": "^6.0.3"
  }
}
